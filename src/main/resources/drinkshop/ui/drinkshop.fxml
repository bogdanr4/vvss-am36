<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drinkshop.ui.DrinkShopController"
            prefWidth="1100"
            prefHeight="800">

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- PRODUSE + COMANDA -->
            <HBox spacing="20">

                <!-- PRODUSE -->
                <VBox spacing="8">
                    <Label text="Produse"/>
                    <TableView fx:id="productTable" prefHeight="150" prefWidth="500">
                        <columns>
                            <TableColumn fx:id="colProdId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colProdName" text="Nume" prefWidth="150"/>
                            <TableColumn fx:id="colProdPrice" text="Pret" prefWidth="80"/>
                            <TableColumn fx:id="colProdCategorie" text="Categorie" prefWidth="110"/>
                            <TableColumn fx:id="colProdTip" text="Tip" prefWidth="110"/>
                        </columns>
                    </TableView>

                    <HBox spacing="8">
                        <TextField fx:id="txtProdName" promptText="Nume"/>
                        <TextField fx:id="txtProdPrice" promptText="Pret"/>
                        <Button text="Add" onAction="#onAddProduct"/>
                        <Button text="Update" onAction="#onUpdateProduct"/>
                        <Button text="Delete" onAction="#onDeleteProduct"/>
                    </HBox>

                    <HBox spacing="15">
                        <VBox spacing="5">
                            <Label text="Categorie"/>
                            <ComboBox fx:id="comboProdCategorie" prefWidth="180"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="Tip Bautura"/>
                            <ComboBox fx:id="comboProdTip" prefWidth="180"/>
                        </VBox>
                    </HBox>

                    <Label text="Filtrare"/>
                    <HBox spacing="8">
                        <Button text="Filter Categorie" onAction="#onFilterCategorie"/>
                        <Button text="Filter Tip" onAction="#onFilterTip"/>
                    </HBox>
                </VBox>

                <!-- COMANDA CURENTA -->
                <VBox spacing="8">
                    <Label text="Comanda curenta"/>

                    <HBox spacing="10">
                        <!-- CONTROALE STANGA -->
                        <VBox spacing="8">
                            <Label text="Cantitate"/>
                            <ComboBox fx:id="comboQty" prefWidth="120"/>

                            <Button text="Add Item" onAction="#onAddOrderItem"/>
                            <Button text="Delete Item" onAction="#onDeleteOrderItem"/>
                            <Button text="Finalizeaza comanda" onAction="#onFinalizeOrder"/>

                            <Label fx:id="lblOrderTotal" text="Total: 0"/>
                        </VBox>

                        <!-- TABEL DREAPTA -->
                        <TableView fx:id="currentOrderTable" prefHeight="150" prefWidth="350">
                            <columns>
                                <TableColumn fx:id="colOrderProdName" text="Produs" prefWidth="220"/>
                                <TableColumn fx:id="colOrderQty" text="Cantitate" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </HBox>

                    <Label text="Receipt"/>
                    <TextArea fx:id="txtReceipt" prefHeight="90" prefWidth="420"/>
                </VBox>

            </HBox>

            <Separator/>

            <!-- RETETE -->
            <HBox spacing="20">
                <VBox spacing="8">
                    <Label text="Retete existente"/>
                    <TableView fx:id="retetaTable" prefHeight="220" prefWidth="500">
                        <columns>
                            <TableColumn fx:id="colRetetaId" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colRetetaDesc" text="Descriere" prefWidth="420"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="8">
                    <Label text="Reteta noua"/>
                    <TableView fx:id="newRetetaTable" prefHeight="180" prefWidth="420">
                        <columns>
                            <TableColumn fx:id="colNewIngredName" text="Ingredient" prefWidth="260"/>
                            <TableColumn fx:id="colNewIngredCant" text="Cantitate" prefWidth="140"/>
                        </columns>
                    </TableView>

                    <HBox spacing="8">
                        <TextField fx:id="txtNewIngredName" promptText="Ingredient"/>
                        <TextField fx:id="txtNewIngredCant" promptText="Cantitate"/>
                    </HBox>

                    <HBox spacing="8">
                        <Button text="Add Ingredient" onAction="#onAddNewIngred"/>
                        <Button text="Delete Ingredient" onAction="#onDeleteNewIngred"/>
                        <Button text="Clear Ingredients" onAction="#onClearNewRetetaIngredients"/>
                        <Button text="Save Reteta" onAction="#onAddNewReteta"/>
                    </HBox>
                </VBox>
            </HBox>

            <Separator/>

            <!-- TIPURI + CATEGORII -->
            <HBox spacing="20">

                <!-- TIPURI -->
                <VBox spacing="8">
                    <Label text="Tipuri bautura"/>
                    <TableView fx:id="tipTable" prefHeight="180" prefWidth="300">
                        <columns>
                            <TableColumn fx:id="colTipId" text="ID" prefWidth="80"/>
                            <TableColumn fx:id="colTipName" text="Nume" prefWidth="200"/>
                        </columns>
                    </TableView>

                    <TextField fx:id="txtTipName" promptText="Nume tip"/>

                    <HBox spacing="8">
                        <Button text="Add Tip" onAction="#onAddTip"/>
                        <Button text="Update Tip" onAction="#onUpdateTip"/>
                        <Button text="Delete Tip" onAction="#onDeleteTip"/>
                    </HBox>
                </VBox>

                <!-- CATEGORII -->
                <VBox spacing="8">
                    <Label text="Categorii bautura"/>
                    <TableView fx:id="categorieTable" prefHeight="180" prefWidth="300">
                        <columns>
                            <TableColumn fx:id="colCategorieId" text="ID" prefWidth="80"/>
                            <TableColumn fx:id="colCategorieName" text="Nume" prefWidth="200"/>
                        </columns>
                    </TableView>

                    <TextField fx:id="txtCategorieName" promptText="Nume categorie"/>

                    <HBox spacing="8">
                        <Button text="Add Categorie" onAction="#onAddCategorie"/>
                        <Button text="Update Categorie" onAction="#onUpdateCategorie"/>
                        <Button text="Delete Categorie" onAction="#onDeleteCategorie"/>
                    </HBox>
                </VBox>

            </HBox>

            <Separator/>

            <!-- EXPORT + REVENUE -->
            <HBox spacing="10">
                <Button text="Export CSV" onAction="#onExportOrdersCsv"/>
                <Button text="Update Revenue" onAction="#onDailyRevenue"/>
                <Label fx:id="lblTotalRevenue" text="Daily Revenue: 0"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>